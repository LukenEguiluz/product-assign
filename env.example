# Copiar a .env en la raíz del repo:  cp env.example .env

# Obligatorio en producción (cadena larga y aleatoria).
DJANGO_SECRET_KEY=cambiar-por-valor-aleatorio-largo

# 0 = producción (recomendado en Docker).
DJANGO_DEBUG=0

# Hosts permitidos (coma, sin espacios). Incluya su dominio o IP del VPS.
# Incluya el dominio o la IP pública con la que acceden al navegador.
ALLOWED_HOSTS=localhost,127.0.0.1,tu-servidor.com

# Puerto HTTP del contenedor nginx en el host (80 si no hay otro servicio).
HTTP_PORT=80

# Si pone HTTPS delante de un proxy (Caddy, Traefik, Cloudflare), active:
# USE_X_FORWARDED_HOST=1
# SECURE_SSL_BEHIND_PROXY=1
# CSRF_TRUSTED_ORIGINS=https://tu-servidor.com

# Solo si la SPA se abre desde otro dominio que el de la API:
# CORS_ALLOWED_ORIGINS=https://otro-dominio.com

# Afinar uso de CPU/RAM (por defecto 1 worker, 2 threads suele bastar en VPS pequeño).
# GUNICORN_WORKERS=1
# GUNICORN_THREADS=2
# GUNICORN_TIMEOUT=120
